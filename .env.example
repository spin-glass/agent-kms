# agent-kms environment variables (template).
#
# Copy to `.env` in the project that uses agent-kms; agent-kms auto-loads
# `./.env` at import. Override the path with AGENT_KMS_ENV_FILE.
# `.env` is git-ignored; never commit real keys.

# ---- Provider selection ------------------------------------------------------
# auto    : try Gemini first, fall back to Anthropic on failure (recommended)
# gemini  : Gemini only
# haiku   : Anthropic only
# ollama  : local Ollama daemon (fully offline, for privacy-sensitive setups)
RAG_PROVIDER=auto
RAG_PROVIDER_FALLBACK=haiku

# ---- Gemini (Google AI Studio — free tier 250 RPD / 4 M tok per day) ---------
# Get key: https://aistudio.google.com/apikey
# NOTE: Free-tier inputs are used by Google for model training.
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-2.5-flash

# ---- Anthropic (Claude Haiku 4.5 — paid, no training on input) ---------------
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---- Ollama (fully local — nothing leaves your machine) ----------------------
# Setup:
#   brew install ollama && ollama serve
#   ollama pull qwen2.5:7b    # or qwen2.5:14b for higher quality
# Then set RAG_PROVIDER=ollama above. Smaller models (<=8B) may struggle with
# the structured JSON output that lesson extraction requires; 14B-class is
# recommended where memory allows.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ---- Qdrant + agent-kms config ---------------------------------------------
# QDRANT_URL=http://localhost:6333
# AGENT_KMS_PRESET=general
# AGENT_KMS_COLLECTION=agent_knowledge
# AGENT_KMS_KNOWLEDGE_ROOT=.
# AGENT_KMS_MODEL=cl-nagoya/ruri-v3-310m
# AGENT_KMS_RETRIEVE_THRESHOLD=0.83
